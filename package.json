{
  "name": "watchdock-errors",
  "version": "0.1.3",
  "description": "Watchdock error tracking SDK for Node.js backends",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicksonlangat/watchdock-errors-typescript-sdk.git"
  },
  "homepage": "https://github.com/nicksonlangat/watchdock-errors-typescript-sdk#readme",
  "bugs": {
    "url": "https://github.com/nicksonlangat/watchdock-errors-typescript-sdk/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/integrations/express.d.ts",
      "default": "./dist/integrations/express.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3"
  }
}
